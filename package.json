{
  "name": "everden",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Everden — a browser RPG by Nanabozho",
  "scripts": {
    "dev": "vite",
    "playtest:nick": "vite --open /nick-playtest.html",
    "nick:summary": "node scripts/summarize-nick-playtest.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy:preview": "npm run build && npx vercel build --prod --yes --scope astral-productions && npx vercel deploy --prebuilt --prod --yes --scope astral-productions",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "audit:creator:visual": "playwright test e2e/creator-full-visual-audit.spec.ts && node scripts/visual-audit-progress.mjs",
    "audit:creator:progress": "node scripts/visual-audit-progress.mjs",
    "atlas:trim-frogwiz": "python3 scripts/trim_frogwiz_atlas.py",
    "atlas:rebuild-frogwiz": "node scripts/rebuild_frogwiz_atlas.mjs",
    "atlas:rebuild-owl": "node scripts/rebuild_atlas.mjs owl assets/source/owl",
    "server:dev": "npm install --prefix server && npm run dev --prefix server",
    "server:build": "npm install --prefix server && npm run build --prefix server",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "colyseus.js": "^0.16.0",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/three": "^0.172.0",
    "eslint": "^10.6.0",
    "happy-dom": "^15.11.7",
    "sharp": "^0.35.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
