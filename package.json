{
  "name": "everden",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Everden — a browser RPG by Nanabozho",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy:preview": "npm run build && npx vercel deploy --prod --yes --scope astral-productions --name everden",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/three": "^0.172.0",
    "eslint": "^10.6.0",
    "happy-dom": "^15.11.7",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
